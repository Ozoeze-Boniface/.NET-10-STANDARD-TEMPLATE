{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    // "DefaultConnection": "Server=localhost;Port=5432;Database=keyrails_banking_api_db;User Id=postgres;Password=postgres;"
    "DefaultConnection": "Server=localhost;Port=5432;Database=keyrails_banking_api_db;User Id=postgres;Password=postgres;",
    "RedisUrl": "127.0.0.1:6379"
  },
  "DatabaseSettings": {
    "Timeout": "300",
    "CommandTimeout": "300",
    "MaxPoolSize": "500",
    "MinPoolSize": "100"
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "keyrails-banking-api-consumer-group",
    "Topic": "KeyRails.BankingApi"
  },
  "RedisKey": {
    "CountKey": "keyrails-banking-api-consumer-count",
    "RequestKey": "keyrails-banking-api-request-key"
  },
  "ExternalServices": {
    "LoggingBaseUrl": "https://dev-eoc-activity-log.sterling.ng/",
    "EocBaseUrl": "https://dev-endofcycle.sterling.ng/"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Elasticsearch"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "Path": "Logs/logs.txt",
          "RollingInterval": "Minute",
          "retainedFileTimeLimit": "1.00:00:00"
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "KeyRails.BankingApi-{0:yyyy.MM.dd}",
          "autoRegisterTemplate": true
        }
      }
    ]
  },
  "ElasticConfiguration": {
    "Uri": "http://172.20.110.105:9200"
  },
  "ASPNETCORE_ENVIRONMENT": {
    "ENVIROMENT": "DEV"
  },

  "RUN_MIGRATIONS": false
}
